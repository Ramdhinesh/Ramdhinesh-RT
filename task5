##Task 4: Factorial Service
def factorial(n):
    if n < 0:
        return "Error: Negative number not allowed"
    elif n == 0:
        return 1
    else:
        return n * factorial(n - 1)

print(factorial(5))
###Task 5: Memory Optimization

def square_generator(n):
    for i in range(n):
        yield i * i

square_list = [i * i for i in range(5)]

square_gen = square_generator(5)

print("List:", square_list)
print("Generator:", list(square_gen))

print(type(square_list))
print(type(square_gen))

